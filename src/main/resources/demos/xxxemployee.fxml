<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.java.controllers.EmployeeController"
            stylesheets="@../css/mouse.css">

    <top>
        <Label text="Employee Dashboard"
               style="-fx-font-size: 18px; -fx-padding: 10;"/>
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Button text="View Tasks" onAction="#viewTasks"/>
            <Button text="View Feedback" onAction="#viewFeedback"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 20;">

            <!-- Task selection -->
            <ComboBox fx:id="taskCombo" promptText="Select Task"/>

            <HBox spacing="10">
                <Button text="Start Timer" onAction="#startTimer"/>
                <Button text="Stop Timer (Complete)" onAction="#stopTimer"/>
            </HBox>

            <TextArea fx:id="outputArea" prefHeight="250"/>

        </VBox>
    </center>

</BorderPane>