<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" prefHeight="271.0" prefWidth="473.0" spacing="15" stylesheets="@../css/mouse.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controllers.LoginController">

    <Label styleClass="title" text="Office Task System" />

    <TextField fx:id="usernameField" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="38.0" prefWidth="220.0" promptText="Username" style="-fx-max-height: 2px;" />
    <PasswordField fx:id="passwordField" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="38.0" prefWidth="220.0" promptText="Password" />

    <Button onAction="#handleLogin" text="Login">
      <VBox.margin>
         <Insets />
      </VBox.margin></Button>

    <Label fx:id="statusLabel" textFill="red" />

</VBox>
